# Step 2.10: Copy local message_parser.py to container (override SDK file)
echo ""
echo "Step 2.10: Copying local message_parser.py to container..."
LOCAL_MESSAGE_PARSER="$PROJECT_ROOT/message_parser.py"
CONTAINER_MESSAGE_PARSER="/workspace/.venv/lib/python3.12/site-packages/claude_agent_sdk/_internal/message_parser.py"

if [ -f "$LOCAL_MESSAGE_PARSER" ]; then
    echo "  Found local message_parser.py at: $LOCAL_MESSAGE_PARSER"
    echo "  Copying to container path: $CONTAINER_MESSAGE_PARSER"
    $CONTAINER_RUNTIME cp "$LOCAL_MESSAGE_PARSER" "$CONTAINER_NAME:$CONTAINER_MESSAGE_PARSER"
    echo "✓ message_parser.py copied successfully"
else
    echo "  Warning: Local message_parser.py not found at $LOCAL_MESSAGE_PARSER"
    echo "  Skipping message_parser override (using default SDK version)"
fi
